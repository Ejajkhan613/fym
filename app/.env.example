EXPO_PUBLIC_API_PORT=4000
EXPO_PUBLIC_ORDER_SOCKET_PORT=4106
EXPO_PUBLIC_API_TIMEOUT_MS=4000

# Optional explicit override. Leave unset in Expo LAN dev so the app can derive
# the host from the Expo dev server and connect to the backend on this port.
# EXPO_PUBLIC_API_BASE_URL=http://localhost:4000
# EXPO_PUBLIC_ORDER_SOCKET_URL=http://localhost:4106
