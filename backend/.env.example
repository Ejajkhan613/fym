NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=*
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fym
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fym_test
DATABASE_SSL=false
DATABASE_MAX_CONNECTIONS=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=5000
JWT_ACCESS_TOKEN_SECRET=change-this-access-token-secret
JWT_REFRESH_TOKEN_SECRET=change-this-refresh-token-secret
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=30d
EXPOSE_DEV_OTP=true
