{
  "name": "@fym/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend workspace for Find Your Medicines microservices.",
  "type": "commonjs",
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "syntax:check": "node scripts/check-syntax.js",
    "test": "jest",
    "verify": "npm run syntax:check && npm run format:check && npm test",
    "db:migrate": "node scripts/migrate.js up",
    "db:status": "node scripts/migrate.js status",
    "start:service": "node scripts/start-service.js",
    "deps": "npm ls --depth=0"
  },
  "keywords": [
    "fym",
    "express",
    "postgresql",
    "redis",
    "kafka",
    "microservices"
  ],
  "author": "",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1062.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "http-errors": "^2.0.1",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "knex": "^3.2.10",
    "multer": "^2.1.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "yamljs": "^0.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2"
  }
}
